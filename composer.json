{
    "name": "csgt/utils",
    "description": "CSGT Utils",
    "authors": [
        {
            "name": "Softlogic",
            "email": "software@softlogic.com.gt"
        }
    ],
    "require": {
        "php" : ">=7.2"
    },
    "autoload": {
        "classmap": [
            "src/Http/Middleware"
        ],
        "psr-4": {
            "Csgt\\Utils\\": "src"
        }
    },
    "require-dev": {
        "orchestra/testbench": "^6.0",
        "phpunit/phpunit": "^9.5"
    },
    "autoload-dev": {
        "psr-4": {
            "Csgt\\Utils\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "minimum-stability" : "stable",
     "extra": {
        "laravel": {
            "providers": [
                "Csgt\\Utils\\UtilsServiceProvider"
            ]
        }
    }
}
